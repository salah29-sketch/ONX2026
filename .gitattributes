# Force LF line endings for all text files — prevents CRLF issues on Windows
* text=auto eol=lf

# Explicitly LF
*.php    text eol=lf
*.blade.php text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.env    text eol=lf
*.neon   text eol=lf
*.sh     text eol=lf

# Binary — no line ending conversion
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.pdf    binary
*.zip    binary
